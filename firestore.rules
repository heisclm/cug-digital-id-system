rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, role, fullName, studentId, department, phoneNumber, createdAt
    //
    // Collection: applications
    // Fields: id, studentUid, photoUrl, status, type, submittedAt, reviewComment
    //
    // Collection: payments
    // Fields: id, applicationId, studentUid, reference, amount, status, paidAt
    //
    // Collection: id_cards
    // Fields: id, studentUid, applicationId, qrData, issueDate, expiryDate, status
    //
    // Collection: students
    // Fields: studentId, fullName, department, program
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isSecurity() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SECURITY';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'fullName']) &&
             data.uid is string && data.email is string &&
             data.role in ['STUDENT', 'ADMIN', 'SECURITY'] &&
             data.fullName is string && data.fullName.size() < 100;
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['studentUid', 'studentId', 'fullName', 'department', 'program', 'photoUrl', 'status', 'type', 'submittedAt']) &&
             data.studentUid == request.auth.uid &&
             data.status == 'PENDING' &&
             data.type in ['NEW', 'RENEWAL'] &&
             data.photoUrl is string &&
             exists(/databases/$(database)/documents/students/$(data.studentId)) &&
             get(/databases/$(database)/documents/students/$(data.studentId)).data.fullName == data.fullName;
    }

    function isValidScan(data) {
      return data.keys().hasAll(['studentId', 'scannedBy', 'scannedAt', 'status']) &&
             data.studentId is string &&
             data.scannedBy == request.auth.uid &&
             data.scannedAt == request.time &&
             data.status in ['VERIFIED', 'EXPIRED', 'INVALID'];
    }

    // Rules
    match /users/{uid} {
      allow read: if isAuthenticated() && (isOwner(uid) || isAdmin() || isSecurity());
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(uid) && request.resource.data.role == resource.data.role));
    }

    match /applications/{id} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentUid) || isAdmin());
      allow create: if isAuthenticated() && isValidApplication(request.resource.data);
      allow update: if isAuthenticated() && isAdmin();
    }

    match /payments/{id} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentUid) || isAdmin());
      // Payments are typically created/updated via webhook (Admin SDK), but we allow read for students to check status
      allow create, update: if false; // Only Admin SDK should write here
    }

    match /id_cards/{id} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentUid) || isAdmin() || isSecurity());
      allow create, update: if isAdmin(); // Allow admins or Admin SDK
    }

    match /students/{studentId} {
      allow read: if isAuthenticated(); // Students need to read this to validate their ID
      allow create, update, delete: if isAdmin(); // Only admins can manage the student database
    }

    match /scans/{id} {
      allow read: if isAdmin() || isSecurity();
      allow create: if (isAdmin() || isSecurity()) && isValidScan(request.resource.data);
    }

    match /notifications/{id} {
      allow read, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
      // Users can only update the 'isRead' field
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      // Only admins or system can create notifications
      allow create: if isAdmin(); 
    }
  }
}
